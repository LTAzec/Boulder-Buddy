// This is your Prisma schema file
// learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  engineType = "client"
  output     = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ===== ENUMS =====


// Rollen voor authenticatie & admin
enum Role {
  User
  Setter
  Admin
  SuperAdmin
}

// Kleur van de boulder
enum BoulderColor {
  White
  Green
  Blue
  Red
  Yellow
  Purple
  Black
  Orange
}

// Fontainebleau grading system, enum mag niet starten met een getal
enum BoulderGrade {
  FB_3
  FB_4
  FB_5A
  FB_5A_plus
  FB_5B
  FB_5B_plus
  FB_5C
  FB_5C_plus
  FB_5
  FB_5_plus
  FB_6A
  FB_6A_plus
  FB_6B
  FB_6B_plus
  FB_6C
  FB_6C_plus
  FB_7A
  FB_7A_plus
  FB_7B
  FB_7B_plus
  FB_7C
  FB_7C_plus
  FB_8A
  FB_8A_plus
  FB_8B
  FB_8B_plus
  FB_8C
  FB_8C_plus
}

// Status van de user bij een boulder
enum LogStatus {
  PROJECT
  SENT
  FLASH
}


// ===== AUTH MODELS (komende uit startbestanden) =====


model User {
  id       String        @id @unique @default(uuid()) @db.Uuid
  email    String        @unique @db.VarChar(255)
  password String
  username String
  role     Role          @default(User)
  sessions Session[]

  // Boulder Buddy relaties
  bouldersSet Boulder[]     @relation("BouldersSetByUser")
  logs         BoulderLog[]
  likes        BoulderLike[]
  comments     Comment[]
}

model Session {
  id          String   @id @unique @default(uuid()) @db.Uuid
  activeFrom  DateTime @default(now())
  activeUntil DateTime
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//
// ===== BOULDER BUDDY DOMAIN MODELS =====
//

// 1 gym (Gustaaf klimt, Turnhout), maar uitbreidbaar
model Gym {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  walls     Wall[]
}

// Een muur in de gym
model Wall {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  gymId     String   @db.Uuid
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sectors   Sector[]
}

// Een sector binnen een muur
model Sector {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  wallId    String   @db.Uuid
  wall      Wall     @relation(fields: [wallId], references: [id], onDelete: Cascade)
  imageUrl String? 
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boulders  Boulder[]
}

// De boulder zelf
model Boulder {
  id           String        @id @default(uuid()) @db.Uuid
  name         String?
  color        BoulderColor
  grade        BoulderGrade
  sectorId     String        @db.Uuid
  sector       Sector        @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  setByUserId  String?       @db.Uuid
  setBy        User?         @relation("BouldersSetByUser", fields: [setByUserId], references: [id])
  setDate      DateTime      @default(now())
  isActive     Boolean       @default(true)
  imageUrl     String?
  videoUrl     String?
  posX         Int?
  posY         Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  logs         BoulderLog[]
  likes        BoulderLike[]
  comments     Comment[]
  tags         BoulderTag[]
}

// Tags zoals "slopers", "compression", ...
model Tag {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  boulders  BoulderTag[]
}

// Many-to-many Boulder <-> Tag
model BoulderTag {
  boulderId String   @db.Uuid
  tagId     String   @db.Uuid

  boulder   Boulder  @relation(fields: [boulderId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([boulderId, tagId])
}

// Logboek van de gebruiker
model BoulderLog {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @db.Uuid
  boulderId   String      @db.Uuid
  status      LogStatus
  attempts    Int         @default(1)
  note        String?
  customName  String?
  videoUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  boulder     Boulder     @relation(fields: [boulderId], references: [id], onDelete: Cascade)
}

// Like per user per boulder
model BoulderLike {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  boulderId   String   @db.Uuid
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boulder     Boulder  @relation(fields: [boulderId], references: [id], onDelete: Cascade)

  @@unique([userId, boulderId])
}

// Commentaar bij een boulder
model Comment {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  boulderId   String   @db.Uuid
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boulder     Boulder  @relation(fields: [boulderId], references: [id], onDelete: Cascade)
}
